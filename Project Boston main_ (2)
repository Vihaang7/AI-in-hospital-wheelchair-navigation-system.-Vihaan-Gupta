{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[],"authorship_tag":"ABX9TyO7pXGtOD4GI78kk8c6wHf1"},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"}},"cells":[{"cell_type":"code","source":["import json, os, re\n","from difflib import get_close_matches\n","from typing import TypedDict, Optional, List\n","import numpy as np\n","import pandas as pd\n","import networkx as nx\n","import matplotlib.pyplot as plt\n","from matplotlib.patches import ConnectionPatch\n","from matplotlib.lines import Line2D\n","\n","try:\n","    from langgraph.graph import StateGraph, START, END\n","    LANGGRAPH_AVAILABLE = True\n","except ImportError:\n","    LANGGRAPH_AVAILABLE = False\n","\n","try:\n","    from langchain_anthropic import ChatAnthropic\n","    LLM_AVAILABLE = True\n","except ImportError:\n","    LLM_AVAILABLE = False\n","\n","\n","class RouteSuitabilityModel:\n","    WEIGHTS_FILE = \"model_weights.json\"\n","\n","    def __init__(self, lr=0.5, epochs=50, seed=42):\n","        self.rng = np.random.default_rng(seed)\n","        self.lr, self.epochs = lr, epochs\n","        if os.path.exists(self.WEIGHTS_FILE):\n","            saved = json.load(open(self.WEIGHTS_FILE))\n","            self.w, self.b, self.total_epochs_trained = np.array(saved[\"w\"]), saved[\"b\"], saved[\"total_epochs_trained\"]\n","            print(f\"Loaded existing weights (trained {self.total_epochs_trained} epochs so far)\")\n","        else:\n","            self.w, self.b, self.total_epochs_trained = self.rng.normal(0, 0.1, 6), 0.0, 0\n","            print(\"No saved weights found, starting fresh\")\n","\n","    def _sigmoid(self, z):\n","        return 1 / (1 + np.exp(-z))\n","\n","    def _accuracy(self, X, y):\n","        return np.mean((self._sigmoid(X @ self.w + self.b) >= 0.5) == y)\n","\n","    def train(self):\n","        n = 2000\n","        dist, acc_frac = self.rng.uniform(0, 1, n), self.rng.uniform(0, 1, n)\n","        wheelchair = self.rng.integers(0, 2, n)\n","        y = np.where(wheelchair == 1, (acc_frac >= 0.999) & (dist < 0.5), dist < 0.35).astype(float)\n","        flip = self.rng.random(n) < 0.03\n","        y[flip] = 1 - y[flip]\n","        X = np.column_stack([dist, acc_frac, wheelchair, wheelchair * acc_frac, wheelchair * dist, acc_frac * dist])\n","        split = int(n * 0.8)\n","        X_train, y_train, X_test, y_test = X[:split], y[:split], X[split:], y[split:]\n","\n","        print(\"Training Route Suitability Model\")\n","        for epoch in range(1, self.epochs + 1):\n","            error = self._sigmoid(X_train @ self.w + self.b) - y_train\n","            self.w -= self.lr * (X_train.T @ error / len(X_train))\n","            self.b -= self.lr * error.mean()\n","            self.total_epochs_trained += 1\n","            print(f\"Epoch {epoch:2d}/{self.epochs} (total {self.total_epochs_trained})  \"\n","                  f\"Train acc: {self._accuracy(X_train, y_train):.4f}  Test acc: {self._accuracy(X_test, y_test):.4f}\")\n","\n","        json.dump({\"w\": self.w.tolist(), \"b\": self.b, \"total_epochs_trained\": self.total_epochs_trained},\n","                   open(self.WEIGHTS_FILE, \"w\"))\n","        print(f\"Saved weights (total epochs trained across all runs: {self.total_epochs_trained})\")\n","\n","    def score(self, dist, acc_frac, wheelchair):\n","        x = np.array([dist, acc_frac, wheelchair, wheelchair * acc_frac, wheelchair * dist, acc_frac * dist])\n","        return self._sigmoid(x @ self.w + self.b)\n","\n","\n","class HospitalNavigator:\n","    def __init__(self, data_dir=\".\"):\n","        self.locations = pd.read_csv(f\"{data_dir}/locations.csv\")\n","        self.coordinates = pd.read_csv(f\"{data_dir}/coordinates.csv\").set_index(\"LocationID\")\n","        self.edges = pd.read_csv(f\"{data_dir}/navigation_edges.csv\")\n","        self.doctors = pd.read_csv(f\"{data_dir}/doctors.csv\")\n","        self.appointments = pd.read_csv(f\"{data_dir}/appointments.csv\")\n","        self.aliases = pd.read_csv(f\"{data_dir}/department_aliases.csv\")\n","        self.landmarks = pd.read_csv(f\"{data_dir}/landmarks.csv\")\n","\n","        self.graph = nx.DiGraph()\n","        for loc_id, row in self.coordinates.iterrows():\n","            self.graph.add_node(loc_id, floor=row[\"Floor\"])\n","        for _, r in self.edges.iterrows():\n","            self.graph.add_edge(r[\"From\"], r[\"To\"], distance=r[\"Distance_m\"], direction=r[\"Direction\"],\n","                                 accessible=str(r[\"Accessible\"]).strip().lower() == \"yes\")\n","\n","        self.name_to_id = {n.lower(): i for n, i in zip(self.locations[\"LocationName\"], self.locations[\"LocationID\"])}\n","        self.alias_to_dept = {a.lower(): d for a, d in zip(self.aliases[\"Alias\"], self.aliases[\"Department\"])}\n","        self.doctor_to_id = {n.lower(): i for n, i in zip(self.doctors[\"DoctorName\"], self.doctors[\"LocationID\"])}\n","        self.apt_to_id = {a.lower(): i for a, i in zip(self.appointments[\"AppointmentID\"], self.appointments[\"LocationID\"])}\n","\n","        self.model = RouteSuitabilityModel()\n","        self.model.train()\n","\n","    def _name(self, loc_id):\n","        row = self.locations[self.locations[\"LocationID\"] == loc_id]\n","        return row.iloc[0][\"LocationName\"] if len(row) else loc_id\n","\n","    def _landmark(self, loc_id):\n","        row = self.landmarks[self.landmarks[\"NearbyLocationID\"] == loc_id]\n","        return row.iloc[0][\"LandmarkName\"] if len(row) else None\n","\n","    def _walk_time(self, distance_m):\n","        \"\"\"Estimated walking time: seconds = distance / 2 (i.e. an assumed 2 m/s pace).\"\"\"\n","        seconds = distance_m / 2\n","        return f\"~{round(seconds)} sec\" if seconds < 60 else f\"~{seconds / 60:.1f} min\"\n","\n","    def _heuristic(self, node, goal):\n","        (x1, y1), (x2, y2) = self.coordinates.loc[node, [\"X\", \"Y\"]], self.coordinates.loc[goal, [\"X\", \"Y\"]]\n","        return float(np.hypot(x2 - x1, y2 - y1))\n","\n","    def resolve_destination(self, query):\n","        q = re.sub(r\"^(take me to|go to|where is|navigate to|i want to go to|i need)\\s+\", \"\",\n","                    query.strip().lower()).strip(\" ?.!\")\n","\n","        apt = re.search(r\"\\bapt\\d+\\b\", q)\n","        if apt and apt.group(0) in self.apt_to_id:\n","            row = self.appointments[self.appointments[\"AppointmentID\"].str.lower() == apt.group(0)].iloc[0]\n","            return self.apt_to_id[apt.group(0)], f\"{row['Department']} (Room {row['Room']})\"\n","\n","        for name, loc_id in {**self.name_to_id, **self.doctor_to_id}.items():\n","            if q in name or name in q:\n","                return loc_id, name.title()\n","\n","        for alias, dept in self.alias_to_dept.items():\n","            if (q in alias or alias in q) and dept.lower() in self.name_to_id:\n","                return self.name_to_id[dept.lower()], dept\n","\n","        close = get_close_matches(q, list(self.name_to_id) + list(self.alias_to_dept) + list(self.doctor_to_id), n=1, cutoff=0.6)\n","        return self.resolve_destination(close[0]) if close else None\n","\n","    def _k_astar_paths(self, start_id, end_id, k=3, penalty=6.0):\n","        \"\"\"Up to k distinct A* routes, penalizing edges already used to nudge\n","        each new search onto a different corridor.\"\"\"\n","        working, paths, attempts = self.graph.copy(), [], 0\n","\n","        while len(paths) < k and attempts < k * 4:\n","            try:\n","                path = nx.astar_path(working, start_id, end_id, heuristic=self._heuristic, weight=\"distance\")\n","            except (nx.NetworkXNoPath, nx.NodeNotFound):\n","                break\n","            if path not in paths:\n","                paths.append(path)\n","            for u, v in zip(path, path[1:]):\n","                if working.has_edge(u, v):\n","                    working[u][v][\"distance\"] *= penalty\n","            attempts += 1\n","\n","        return paths\n","\n","    def find_best_path(self, start_id, end_id, wheelchair=False, k=3):\n","        paths = self._k_astar_paths(start_id, end_id, k=k)\n","        if not paths:\n","            return None\n","\n","        candidates = [(p, sum(self.graph[u][v][\"distance\"] for u, v in zip(p, p[1:])),\n","                       np.mean([self.graph[u][v][\"accessible\"] for u, v in zip(p, p[1:])])) for p in paths]\n","\n","        min_d, max_d = min(c[1] for c in candidates), max(c[1] for c in candidates)\n","        span = max(max_d - min_d, 1e-6)\n","\n","        scored = [(self.model.score((d - min_d) / span, a, wheelchair), p, d)\n","                  for p, d, a in candidates if not wheelchair or a >= 0.999]\n","        return max(scored, key=lambda t: t[0]) if scored else None\n","\n","    def build_directions(self, path):\n","        steps = []\n","        for u, v in zip(path, path[1:]):\n","            edge = self.graph[u][v]\n","            name, landmark = self._name(v), self._landmark(v)\n","            step = f\"Take the lift to reach {name}.\" if \"Lift\" in edge[\"direction\"] else \\\n","                   f\"Go {edge['direction'].lower()} for {edge['distance']}m to reach {name}.\"\n","            steps.append(step + (f\" (Landmark: {landmark})\" if landmark else \"\"))\n","        return steps\n","\n","    def plot_route(self, path, title=\"\", distance=None):\n","        floors = list(dict.fromkeys(self.coordinates.loc[i, \"Floor\"] for i in path))\n","        fig, axes = plt.subplots(1, len(floors), figsize=(7.5 * len(floors), 6.5))\n","        axes = [axes] if len(floors) == 1 else list(axes)\n","        legend = {}\n","        floor_panels = {}  # floor -> (ax, pts, xs, ys), used to connect floors with a \"via lift\" line\n","\n","        for ax, floor in zip(axes, floors):\n","            fc = self.coordinates[self.coordinates[\"Floor\"] == floor]\n","            ax.set_facecolor(\"#f7f7f9\")\n","            ax.scatter(fc[\"X\"], fc[\"Y\"], c=\"#d0d0d5\", s=70, zorder=2, edgecolors=\"white\", linewidths=0.5)\n","            for loc_id, row in fc.iterrows():\n","                ax.annotate(self._name(loc_id), (row[\"X\"], row[\"Y\"]), fontsize=7, color=\"#555\",\n","                            xytext=(4, 4), textcoords=\"offset points\")\n","\n","            pts = [i for i in path if self.coordinates.loc[i, \"Floor\"] == floor]\n","            xs = self.coordinates.loc[pts, \"X\"].to_numpy() if pts else np.array([])\n","            ys = self.coordinates.loc[pts, \"Y\"].to_numpy() if pts else np.array([])\n","            floor_panels[floor] = (ax, pts, xs, ys)\n","\n","            if len(pts) >= 2:\n","                for i in range(len(xs) - 1):\n","                    ax.annotate(\"\", xy=(xs[i + 1], ys[i + 1]), xytext=(xs[i], ys[i]),\n","                                arrowprops=dict(arrowstyle=\"-|>\", color=\"#2b6cb0\", lw=2.5, shrinkA=9, shrinkB=9), zorder=3)\n","                    mx, my = (xs[i] + xs[i + 1]) / 2, (ys[i] + ys[i + 1]) / 2\n","                    ax.annotate(f\"{self.graph[pts[i]][pts[i + 1]]['distance']}m\", (mx, my), fontsize=6.5,\n","                                color=\"#2b6cb0\", ha=\"center\", va=\"center\",\n","                                bbox=dict(boxstyle=\"round,pad=0.15\", fc=\"white\", ec=\"none\", alpha=0.85))\n","                ax.scatter(xs, ys, c=\"#2b6cb0\", s=100, zorder=4, edgecolors=\"white\", linewidths=1)\n","                for n, (x, y) in enumerate(zip(xs, ys), 1):\n","                    ax.annotate(str(n), (x, y), fontsize=7, color=\"white\", fontweight=\"bold\",\n","                                ha=\"center\", va=\"center\", zorder=5)\n","            elif len(pts) == 1:\n","                ax.scatter(*self.coordinates.loc[pts[0], [\"X\", \"Y\"]], c=\"#2b6cb0\", s=100, zorder=4)\n","\n","            if path[0] in pts:\n","                legend[\"Start\"] = ax.scatter(*self.coordinates.loc[path[0], [\"X\", \"Y\"]], c=\"#2f855a\", s=180,\n","                                              edgecolors=\"black\", zorder=6)\n","            if path[-1] in pts:\n","                legend[\"Destination\"] = ax.scatter(*self.coordinates.loc[path[-1], [\"X\", \"Y\"]], c=\"#c53030\", s=220,\n","                                                    marker=\"*\", edgecolors=\"black\", zorder=6)\n","\n","            ax.set_title(f\"{floor} Floor\", fontsize=11, fontweight=\"bold\")\n","            ax.set_xticks([]); ax.set_yticks([])\n","            for spine in ax.spines.values():\n","                spine.set_visible(False)\n","\n","        time_str = f\"  |  Est. walk time: {self._walk_time(distance)}\" if distance is not None else \"\"\n","        fig.suptitle(f\"{title}  (A* Optimized Route){time_str}\", fontsize=14, fontweight=\"bold\")\n","        plt.tight_layout(rect=[0, 0.04, 1, 1])\n","\n","        # Connect consecutive floor panels with a dashed \"via lift\" line, so a floor\n","        # change reads as one continuous route instead of two disconnected panels.\n","        has_lift_connector = False\n","        for f1, f2 in zip(floors, floors[1:]):\n","            ax1, pts1, xs1, ys1 = floor_panels[f1]\n","            ax2, pts2, xs2, ys2 = floor_panels[f2]\n","            if len(pts1) == 0 or len(pts2) == 0:\n","                continue\n","            p1, p2 = (xs1[-1], ys1[-1]), (xs2[0], ys2[0])\n","            con = ConnectionPatch(xyA=p1, coordsA=\"data\", axesA=ax1,\n","                                   xyB=p2, coordsB=\"data\", axesB=ax2,\n","                                   color=\"#805ad5\", linestyle=\"--\", linewidth=2,\n","                                   arrowstyle=\"-|>\", mutation_scale=18, zorder=10)\n","            fig.add_artist(con)\n","            has_lift_connector = True\n","\n","            fx1, fy1 = fig.transFigure.inverted().transform(ax1.transData.transform(p1))\n","            fx2, fy2 = fig.transFigure.inverted().transform(ax2.transData.transform(p2))\n","            fig.text((fx1 + fx2) / 2, (fy1 + fy2) / 2, \"via lift\", fontsize=8, color=\"#805ad5\",\n","                      fontweight=\"bold\", ha=\"center\", va=\"center\",\n","                      bbox=dict(boxstyle=\"round,pad=0.2\", fc=\"white\", ec=\"#805ad5\", alpha=0.9), zorder=11)\n","\n","        if has_lift_connector:\n","            legend[\"Via Lift\"] = Line2D([0], [0], color=\"#805ad5\", linestyle=\"--\", linewidth=2)\n","        if legend:\n","            fig.legend(legend.values(), legend.keys(), loc=\"lower center\", ncol=len(legend), frameon=False)\n","\n","        plt.show()\n","\n","    def navigate(self, query, start_id=\"G01\", wheelchair=False, show_map=True):\n","        resolved = self.resolve_destination(query)\n","        if not resolved:\n","            print(f\"Sorry, I couldn't find '{query}'.\")\n","            return None\n","        dest_id, dest_name = resolved\n","        start_name = self._name(start_id)\n","\n","        result = self.find_best_path(start_id, dest_id, wheelchair)\n","        if not result:\n","            print(f\"No route found from {start_name} to {dest_name}.\")\n","            return None\n","\n","        suitability, path, distance = result\n","        directions = self.build_directions(path)\n","\n","        walk_time = self._walk_time(distance)\n","        print(f\"\\nDestination: {dest_name}\")\n","        print(f\"Route (A*): {start_name} -> {dest_name}  |  Distance: {distance}m  |  \"\n","              f\"Est. walk time: {walk_time}  |  Suitability: {suitability:.4f}\")\n","        for i, step in enumerate(directions, 1):\n","            print(f\"{i}. {step}\")\n","\n","        if show_map:\n","            self.plot_route(path, title=f\"{start_name} -> {dest_name}\", distance=distance)\n","\n","        return {\"path\": path, \"distance\": distance, \"directions\": directions}\n","\n","\n","class NavState(TypedDict, total=False):\n","    \"\"\"Shared state passed between agents in the LangGraph workflow.\"\"\"\n","    query: str\n","    start_id: str\n","    wheelchair: bool\n","    dest_id: str\n","    dest_name: str\n","    path: List\n","    distance: float\n","    directions: List[str]\n","    suitability: float\n","    accessibility_note: str\n","    final_response: str\n","    error: str\n","\n","\n","def build_navigation_graph(nav: \"HospitalNavigator\"):\n","    \"\"\"Wires up a 4-agent LangGraph workflow around one HospitalNavigator instance:\n","\n","      Resolver Agent  -> figures out which location the user means from free text\n","      Routing Agent   -> runs A* to find the best path and its raw turn-by-turn steps\n","      Accessibility Agent -> reviews the chosen path for wheelchair-accessibility concerns\n","      Concierge Agent -> turns all of the above into the final message shown to the user\n","\n","    Each agent only touches its own slice of the shared NavState; if Resolver or Routing\n","    hit a dead end they set \"error\" and the graph short-circuits straight to END.\n","    \"\"\"\n","    if not LANGGRAPH_AVAILABLE:\n","        raise ImportError(\n","            \"langgraph isn't installed. Run: pip install langgraph langchain-anthropic\"\n","        )\n","\n","    def resolver_agent(state: NavState) -> dict:\n","        resolved = nav.resolve_destination(state[\"query\"])\n","        if not resolved:\n","            return {\"error\": f\"Sorry, I couldn't find '{state['query']}'.\"}\n","        dest_id, dest_name = resolved\n","        return {\"dest_id\": dest_id, \"dest_name\": dest_name}\n","\n","    def routing_agent(state: NavState) -> dict:\n","        result = nav.find_best_path(state[\"start_id\"], state[\"dest_id\"], state.get(\"wheelchair\", False))\n","        if not result:\n","            start_name = nav._name(state[\"start_id\"])\n","            return {\"error\": f\"No route found from {start_name} to {state['dest_name']}.\"}\n","        suitability, path, distance = result\n","        directions = nav.build_directions(path)\n","        return {\"path\": path, \"distance\": distance, \"directions\": directions, \"suitability\": suitability}\n","\n","    def accessibility_agent(state: NavState) -> dict:\n","        if not state.get(\"wheelchair\"):\n","            return {\"accessibility_note\": \"\"}\n","        path = state[\"path\"]\n","        acc_frac = np.mean([nav.graph[u][v][\"accessible\"] for u, v in zip(path, path[1:])])\n","        if acc_frac >= 0.999:\n","            note = \"This route uses only fully wheelchair-accessible segments.\"\n","        else:\n","            note = (f\"Heads up: only {acc_frac * 100:.0f}% of this route's segments are marked \"\n","                    \"wheelchair-accessible in our data — consider asking staff to confirm before heading out.\")\n","        return {\"accessibility_note\": note}\n","\n","    def concierge_agent(state: NavState) -> dict:\n","        walk_time = nav._walk_time(state[\"distance\"])\n","        directions_block = \"\\n\".join(f\"{i}. {s}\" for i, s in enumerate(state[\"directions\"], 1))\n","        note = state.get(\"accessibility_note\", \"\")\n","\n","        if LLM_AVAILABLE and os.environ.get(\"ANTHROPIC_API_KEY\"):\n","            llm = ChatAnthropic(model=\"claude-sonnet-4-5\")\n","            prompt = (\n","                f\"Write a short, warm set of walking directions for a hospital visitor heading to \"\n","                f\"{state['dest_name']}. Distance is {state['distance']}m (~{walk_time}). \"\n","                f\"Use exactly these steps, don't invent new ones:\\n{directions_block}\\n\"\n","                f\"{('Accessibility note: ' + note) if note else ''}\"\n","            )\n","            final = llm.invoke(prompt).content\n","        else:\n","            final = f\"Heading to {state['dest_name']} — about {state['distance']}m, roughly {walk_time}.\\n\\n{directions_block}\"\n","            if note:\n","                final += f\"\\n\\n{note}\"\n","\n","        return {\"final_response\": final}\n","\n","    graph = StateGraph(NavState)\n","    graph.add_node(\"resolver_agent\", resolver_agent)\n","    graph.add_node(\"routing_agent\", routing_agent)\n","    graph.add_node(\"accessibility_agent\", accessibility_agent)\n","    graph.add_node(\"concierge_agent\", concierge_agent)\n","\n","    graph.add_edge(START, \"resolver_agent\")\n","    graph.add_conditional_edges(\n","        \"resolver_agent\",\n","        lambda s: \"error\" if s.get(\"error\") else \"ok\",\n","        {\"error\": END, \"ok\": \"routing_agent\"},\n","    )\n","    graph.add_conditional_edges(\n","        \"routing_agent\",\n","        lambda s: \"error\" if s.get(\"error\") else \"ok\",\n","        {\"error\": END, \"ok\": \"accessibility_agent\"},\n","    )\n","    graph.add_edge(\"accessibility_agent\", \"concierge_agent\")\n","    graph.add_edge(\"concierge_agent\", END)\n","\n","    return graph.compile()\n","\n","\n","def navigate_multi_agent(nav: \"HospitalNavigator\", query, start_id=\"G01\", wheelchair=False, show_map=True):\n","    \"\"\"Runs the 4-agent workflow end to end and prints each agent's contribution as it resolves.\"\"\"\n","    app = build_navigation_graph(nav)\n","    initial_state: NavState = {\"query\": query, \"start_id\": start_id, \"wheelchair\": wheelchair}\n","    result = app.invoke(initial_state)\n","\n","    if result.get(\"error\"):\n","        print(result[\"error\"])\n","        return None\n","\n","    print(f\"\\n[Resolver Agent] Destination identified: {result['dest_name']}\")\n","    print(f\"[Routing Agent] Path found via A*  |  distance {result['distance']}m  |  \"\n","          f\"suitability {result['suitability']:.4f}\")\n","    if result.get(\"accessibility_note\"):\n","        print(f\"[Accessibility Agent] {result['accessibility_note']}\")\n","    print(f\"[Concierge Agent]\\n{result['final_response']}\")\n","\n","    if show_map:\n","        nav.plot_route(result[\"path\"], title=f\"{nav._name(start_id)} -> {result['dest_name']}\",\n","                        distance=result[\"distance\"])\n","\n","    return result\n","\n","\n","def run_interactive():\n","    nav = HospitalNavigator(data_dir=\".\")\n","    print(\"\\nWelcome! I can guide you anywhere in the hospital.\")\n","    destination = input(\"Where would you like to go? \").strip()\n","    wheelchair = input(\"Do you need a wheelchair-accessible route? (yes/no): \").strip().lower() in (\"yes\", \"y\")\n","    nav.navigate(destination, start_id=\"G01\", wheelchair=wheelchair)\n","\n","\n","def run_interactive_multi_agent():\n","    if not LANGGRAPH_AVAILABLE:\n","        print(\"langgraph isn't installed (pip install langgraph langchain-anthropic). \"\n","              \"Falling back to the single-agent navigator.\\n\")\n","        return run_interactive()\n","\n","    nav = HospitalNavigator(data_dir=\".\")\n","    print(\"\\nWelcome! I can guide you anywhere in the hospital (multi-agent mode).\")\n","    destination = input(\"Where would you like to go? \").strip()\n","    wheelchair = input(\"Do you need a wheelchair-accessible route? (yes/no): \").strip().lower() in (\"yes\", \"y\")\n","    navigate_multi_agent(nav, destination, start_id=\"G01\", wheelchair=wheelchair)\n","\n","\n","if __name__ == \"__main__\":\n","    run_interactive_multi_agent()"],"metadata":{"id":"QjO4jIVdG0q_","colab":{"base_uri":"https://localhost:8080/","height":1000},"executionInfo":{"status":"ok","timestamp":1783779721782,"user_tz":-720,"elapsed":18737,"user":{"displayName":"VIHAAN","userId":"09373577483292243737"}},"outputId":"27333e91-3538-439e-a0f1-9011b3cd439a"},"execution_count":28,"outputs":[{"output_type":"stream","name":"stdout","text":["No saved weights found, starting fresh\n","Training Route Suitability Model\n","Epoch  1/50 (total 1)  Train acc: 0.7969  Test acc: 0.8050\n","Epoch  2/50 (total 2)  Train acc: 0.7969  Test acc: 0.8050\n","Epoch  3/50 (total 3)  Train acc: 0.7969  Test acc: 0.8050\n"