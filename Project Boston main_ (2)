]},{"cell_type":"code","source":["import json\n","import os\n","import numpy as np\n","\n","\n","class RouteSuitabilityModel:\n","\n","    WEIGHTS_FILE = \"model_weights.json\"\n","\n","    def __init__(self, lr=0.5, epochs=50, seed=42):\n","        self.rng = np.random.default_rng(seed)\n","        self.lr, self.epochs = lr, epochs\n","\n","        # 6 features: dist, acc_frac, wheelchair, + 3 interaction terms.\n","        # The interaction terms let the model represent the AND-shaped rule\n","        # (\"wheelchair AND high accessibility AND short distance\") that plain\n","        # linear features alone can't express — this raises the accuracy ceiling.\n","        if os.path.exists(self.WEIGHTS_FILE):\n","            saved = json.load(open(self.WEIGHTS_FILE))\n","            self.w = np.array(saved[\"w\"])\n","            self.b = saved[\"b\"]\n","            self.total_epochs_trained = saved[\"total_epochs_trained\"]\n","            print(f\"Loaded existing weights (trained {self.total_epochs_trained} epochs so far)\")\n","        else:\n","            self.w = self.rng.normal(0, 0.1, 6)\n","            self.b = 0.0\n","            self.total_epochs_trained = 0\n","            print(\"No saved weights found, starting fresh\")\n","\n","    def _sigmoid(self, z):\n","        return 1 / (1 + np.exp(-z))\n","\n","    def _accuracy(self, X, y):\n","        return np.mean((self._sigmoid(X @ self.w + self.b) >= 0.5) == y)\n","\n","    def train(self):\n","        n = 2000\n","        dist = self.rng.uniform(0, 1, n)\n","        acc_frac = self.rng.uniform(0, 1, n)\n","        wheelchair = self.rng.integers(0, 2, n)\n","        y = np.where(wheelchair == 1, (acc_frac >= 0.999) & (dist < 0.5), dist < 0.35).astype(float)\n","        flip = self.rng.random(n) < 0.03  # 3% label noise -> ~97% is the practical ceiling\n","        y[flip] = 1 - y[flip]\n","\n","        X = np.column_stack([dist, acc_frac, wheelchair,\n","                              wheelchair * acc_frac, wheelchair * dist, acc_frac * dist])\n","\n","        split = int(n * 0.9)\n","        X_train, y_train, X_test, y_test = X[:split], y[:split], X[split:], y[split:]\n","\n","        print(\"Training Route Suitability Model\")\n","        for epoch in range(1, self.epochs + 1):\n","            error = self._sigmoid(X_train @ self.w + self.b) - y_train\n","            self.w -= self.lr * (X_train.T @ error / len(X_train))\n","            self.b -= self.lr * error.mean()\n","            self.total_epochs_trained += 1\n","            print(f\"Epoch {epoch:2d}/{self.epochs} (total {self.total_epochs_trained})  \"\n","                  f\"Train acc: {self._accuracy(X_train, y_train):.4f}  Test acc: {self._accuracy(X_test, y_test):.4f}\")\n","\n","        json.dump({\"w\": self.w.tolist(), \"b\": self.b, \"total_epochs_trained\": self.total_epochs_trained},\n","                   open(self.WEIGHTS_FILE, \"w\"))\n","        print(f\"Saved weights (total epochs trained across all runs: {self.total_epochs_trained})\")\n","\n","    def score(self, dist, acc_frac, wheelchair):\n","        x = np.array([dist, acc_frac, wheelchair, wheelchair * acc_frac, wheelchair * dist, acc_frac * dist])\n","        return self._sigmoid(x @ self.w + self.b)\n","\n","\n","if __name__ == \"__main__\":\n","    m = RouteSuitabilityModel(epochs=30)\n","    m.train()\n"],"metadata":{"id":"5mzWsJjpPPlX","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1783779633117,"user_tz":-720,"elapsed":18,"user":{"displayName":"VIHAAN","userId":"09373577483292243737"}},"outputId":"e778e2e7-71c1-40d9-f600-7b4b1c191b5f"},"execution_count":27,"outputs":[{"output_type":"stream","name":"stdout","text":["Loaded existing weights (trained 780 epochs so far)\n","Training Route Suitability Model\n","Epoch  1/30 (total 781)  Train acc: 0.9650  Test acc: 0.9700\n","Epoch  2/30 (total 782)  Train acc: 0.9650  Test acc: 0.9700\n","Epoch  3/30 (total 783)  Train acc: 0.9650  Test acc: 0